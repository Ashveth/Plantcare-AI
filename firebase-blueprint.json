{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" }
      },
      "required": ["uid", "email"]
    },
    "Plant": {
      "title": "Plant Profile",
      "description": "Detailed information about a user's plant, including AI-generated care guides and history.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique plant ID" },
        "ownerUid": { "type": "string", "description": "UID of the user who owns this plant" },
        "name": { "type": "string", "description": "Name of the plant" },
        "species": { "type": "string", "description": "Species or type of the plant" },
        "isIndoor": { "type": "boolean", "description": "Whether the plant is indoors" },
        "plantationDate": { "type": "string", "format": "date-time", "description": "ISO 8601 date of plantation" },
        "location": { "type": "string", "description": "Location (balcony, room, garden, etc.)" },
        "potSize": { "type": "string", "description": "Size of the pot" },
        "imageUrl": { "type": "string", "description": "URL to the plant's image" },
        "expectedLifespan": { "type": "string", "description": "AI-generated expected lifespan" },
        "healthStatus": { "type": "string", "description": "Current health status (AI generated)" },
        "description": { "type": "string", "description": "AI-generated description of the plant" },
        "careRequirements": {
          "type": "object",
          "description": "AI-generated care requirements (watering, sunlight, etc.)"
        },
        "fertilizerSchedule": {
          "type": "object",
          "description": "AI-generated lifetime fertilizer schedule"
        },
        "notificationsEnabled": { "type": "boolean", "description": "Whether care notifications are enabled" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["ownerUid", "name", "species", "isIndoor", "plantationDate", "location"]
    },
    "FarmerLog": {
      "title": "Farmer Diary Log",
      "description": "A log entry for farming activities like fertilizer usage, irrigation, sowing, etc.",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string", "description": "UID of the user who owns this log" },
        "date": { "type": "string", "format": "date-time", "description": "ISO 8601 date of the activity" },
        "type": { "type": "string", "enum": ["fertilizer", "pesticide", "irrigation", "sowing", "harvest", "expense", "income"], "description": "Type of activity" },
        "cropName": { "type": "string", "description": "Name of the crop or plant" },
        "productName": { "type": "string", "description": "Name of the product used (if applicable)" },
        "quantity": { "type": "string", "description": "Quantity used or harvested" },
        "areaCovered": { "type": "string", "description": "Land or area covered" },
        "cost": { "type": "number", "description": "Cost or income amount (optional)" },
        "notes": { "type": "string", "description": "Additional notes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["ownerUid", "date", "type", "cropName"]
    },
    "Event": {
      "title": "Plant Event",
      "description": "An event in the plant's lifetime (care task, health issue, or milestone).",
      "type": "object",
      "properties": {
        "plantId": { "type": "string", "description": "ID of the plant" },
        "type": { "type": "string", "enum": ["watering", "fertilizing", "repotting", "pruning", "health_issue", "milestone"], "description": "Type of event" },
        "date": { "type": "string", "format": "date-time", "description": "ISO 8601 date of the event" },
        "status": { "type": "string", "enum": ["pending", "completed", "skipped", "snoozed", "resolved"], "description": "Status of the event" },
        "notes": { "type": "string", "description": "User notes or log details" },
        "aiDiagnosis": { "type": "string", "description": "AI-generated diagnosis for health issues" },
        "aiSolution": { "type": "string", "description": "AI-generated solution for health issues" }
      },
      "required": ["plantId", "type", "date", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/plants/{plantId}": {
      "schema": "Plant",
      "description": "Plant profile documents"
    },
    "/plants/{plantId}/events/{eventId}": {
      "schema": "Event",
      "description": "History and scheduled events for a specific plant"
    },
    "/farmer_logs/{logId}": {
      "schema": "FarmerLog",
      "description": "Farmer diary log entries"
    }
  }
}
